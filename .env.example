# =============================================================================
# SentinelAI — Environment Variables Template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# See docs/API_KEYS_SETUP.md for where to obtain each key.
# =============================================================================

# ---- App ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- HuggingFace Inference API ----
# https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_AUDIO_MODEL=facebook/wav2vec2-base-960h
HF_ZEROSHOT_MODEL=MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli
HF_VISION_MODEL=google/vit-base-patch16-224

# ---- Groq (Llama 3 inference) ----
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# ---- Resemble AI (optional — real-time voice clone detection) ----
RESEMBLE_API_KEY=

# ---- Neo4j (Graph fraud-network intelligence) ----
# Use Neo4j Sandbox or Aura Free: https://neo4j.com/sandbox/
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ---- Redis (scam-call session state) ----
REDIS_URL=redis://localhost:6379/0

# ---- Supabase (PostgreSQL logging of mock reports) ----
# https://supabase.com/dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=

# ---- WhatsApp Cloud API ----
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=sentinelai_verify_token

# ---- Frontend (Mapbox for hotspot map) ----
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
